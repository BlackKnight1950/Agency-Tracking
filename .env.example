# Your Smartsheet API access token
# Get it from: Smartsheet → Account → Personal Settings → API Access
SMARTSHEET_TOKEN=your_smartsheet_token_here

# Port (Render sets this automatically — leave as 3000 for local dev)
PORT=3000
